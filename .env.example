# Telegram Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (from @userinfobot)
ALLOWED_USER_ID=123456789

# Qwen API key from dashscope.aliyuncs.com
QWEN_API_KEY=sk-...

# Qwen base URL (default: international endpoint)
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Database URL (default: SQLite in ./data/bot.db)
DB_URL=sqlite+aiosqlite:///data/bot.db

# LLM model to use (qwen-turbo / qwen-plus / qwen-max)
LLM_MODEL=qwen-turbo

# Max messages in context window
MAX_CONTEXT_MESSAGES=20

# Injection protection: hardened system prompt + input/output guards
# Set to false to demo unprotected mode (attack succeeds)
INJECTION_PROTECTION_ENABLED=true
